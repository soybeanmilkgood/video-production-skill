{
  "tts": {
    "provider": "qwen3-tts",
    "baseURL": "http://localhost:8001/v1",
    "model": "Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice",
    "voice": "vivian",
    "response_format": "wav",
    "speed": 1.0,
    "maxRetries": 5
  },
  "asr": {
    "provider": "qwen3-asr",
    "condaEnv": "qwen3-asr",
    "model": "Qwen/Qwen3-ASR-1.7B",
    "forcedAligner": "Qwen/Qwen3-ForcedAligner-0.6B",
    "passThreshold": 0.85
  },
  "image": {
    "provider": "ernie-image-turbo",
    "baseURL": "http://localhost:8080/v1",
    "model": "ERNIE-Image-Turbo",
    "size": "1024x576",
    "steps": 8,
    "cfgScale": 1.0
  },
  "chat": {
    "baseURL": "https://opencode.ai/zen/go/v1",
    "model": "opencode-go/deepseek-v4-flash"
  },
  "video": {
    "width": 1920,
    "height": 1080,
    "audioBitrate": "192k",
    "slidePadding": 1.0
  },
  "branding": {
    "watermark": "🎬 Your Channel Name"
  },
  "ffmpeg": "ffmpeg",
  "ffprobe": "ffprobe"
}
