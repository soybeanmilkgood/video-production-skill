{
  "tts": {
    "provider": "vllm-omni",
    "baseURL": "http://localhost:8001",
    "model": "Qwen/Qwen3-TTS-12Hz-1.7B-Base",
    "voice": "papaya",
    "language": "Chinese",
    "task_type": "Base",
    "nonStreamingMode": true,
    "warmup": true,
    "response_format": "wav",
    "maxRetries": 5
  },
  "asr": {
    "provider": "qwen3-asr",
    "baseURL": "http://localhost:8012",
    "passThreshold": 0.85,
    "concurrency": 4
  },
  "image": {
    "provider": "ernie-image-turbo",
    "baseURL": "http://localhost:8080/v1",
    "model": "ERNIE-Image-Turbo",
    "size": "1024x576",
    "steps": 8,
    "cfgScale": 1.0
  },
  "chat": {
    "baseURL": "https://opencode.ai/zen/go/v1",
    "model": "deepseek-v4-flash"
  },
  "video": {
    "width": 1920,
    "height": 1080,
    "audioBitrate": "192k",
    "slidePadding": 1.0
  },
  "branding": {
    "watermark": "🎬 Your Channel Name"
  },
  "subtitles": {
    "fontName": "Noto Sans CJK TC",
    "fontSize": 22,
    "marginV": 40,
    "outline": 2
  },
  "ffmpeg": "ffmpeg",
  "ffprobe": "ffprobe"
}
